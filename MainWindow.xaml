<Window x:Class="ElGamalLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторная работа: Эль-Гамаль (Вариант 2)" Height="700" Width="900">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель параметров -->
        <GroupBox Header="Параметры алгоритма" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Простое число p:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtP" Width="80" Text="257" Margin="5"/>

                <TextBlock Text="Секретный ключ x:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtX" Width="80" Text="5" Margin="5"/>

                <TextBlock Text="Случайное k:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="TxtK" Width="80" Text="7" Margin="5"/>

                <Button Content="Рассчитать корни g" Click="BtnCalculateRoots_Click" Margin="10,0,0,0" Padding="10,5"/>
            </StackPanel>
        </GroupBox>

        <!-- Выбор генератора g -->
        <GroupBox Header="Выбор генератора (g)" Grid.Row="1" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Найденные первообразные корни (выберите один):" Margin="5"/>
                <ListBox x:Name="LbRoots" Height="60" SelectionMode="Single" Margin="5"/>
                <TextBlock x:Name="TxtSelectedG" Text="Выберите g из списка выше" Foreground="Gray" Margin="5"/>
            </StackPanel>
        </GroupBox>

        <!-- Управление файлами -->
        <GroupBox Header="Файловые операции" Grid.Row="2" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TxtFilePath" Text="Файл не выбран" Margin="5"/>
                    <Button Content="Выбрать файл для шифрования" Click="BtnSelectFile_Click" Margin="5" HorizontalAlignment="Left"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                    <Button Content="Зашифровать" Click="BtnEncrypt_Click" Width="120" Margin="0,5" Background="#FFAADDAA"/>
                    <Button Content="Расшифровать" Click="BtnDecrypt_Click" Width="120" Margin="0,5" Background="#FFAAAADD"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Лог и результаты -->
        <GroupBox Header="Результат / Лог" Grid.Row="4" Margin="0,0,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" Background="#FFF0F0F0"/>
            </ScrollViewer>
        </GroupBox>

        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов к работе"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>